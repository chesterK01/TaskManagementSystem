@model TaskManagementSystem.Web.Models.UserViewModel
@{
    ViewData["Title"] = "Chi tiết tài khoản";
}

<h3>Chi tiết tài khoản</h3>

<dl class="row col-md-6">
    <dt class="col-sm-4">Tên đăng nhập</dt>
    <dd class="col-sm-8">@Model.UserName</dd>
    <dt class="col-sm-4">Họ tên</dt>
    <dd class="col-sm-8">@Model.FullName</dd>
    <dt class="col-sm-4">Email</dt>
    <dd class="col-sm-8">@Model.Email</dd>
    <dt class="col-sm-4">Số điện thoại</dt>
    <dd class="col-sm-8">@Model.Phone</dd>
    <dt class="col-sm-4">Vai trò</dt>
    <dd class="col-sm-8">@Model.RoleName</dd>
    <dt class="col-sm-4">Trạng thái</dt>
    <dd class="col-sm-8">@(Model.IsActive ? "Đang hoạt động" : "Đã khóa")</dd>
</dl>

<a asp-action="Index" class="btn btn-secondary">Quay lại</a>