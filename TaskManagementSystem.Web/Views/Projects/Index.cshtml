@model IEnumerable<TaskManagementSystem.Web.Models.ProjectViewModel>
@{
    ViewData["Title"] = "Danh sách dự án";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3>Danh sách dự án</h3>
    <a asp-action="Create" class="btn btn-primary">+ Tạo dự án mới</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-3">
    @foreach (var p in Model)
    {
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <h5 class="card-title">@p.ProjectName</h5>
                        <span class="badge bg-secondary align-self-start">@p.StatusName</span>
                    </div>
                    <p class="card-text text-muted small">@p.Description</p>
                    <p class="mb-1"><small class="text-muted">Thành viên: @p.MemberCount &nbsp;|&nbsp; Công việc: @p.TaskCount</small></p>
                    <p class="mb-2"><small class="text-muted">Tạo bởi: @p.CreatedByName</small></p>
                    <a asp-action="Details" asp-route-id="@p.ProjectId" class="btn btn-sm btn-outline-primary">Xem chi tiết</a>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <p class="text-muted mt-3">Chưa có dự án nào.</p>
}