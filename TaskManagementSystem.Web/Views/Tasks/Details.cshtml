@model TaskManagementSystem.Web.Models.ProjectTaskViewModel
@{
    ViewData["Title"] = Model.Title;
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h3>@Model.Title</h3>
        <p class="text-muted">@Model.Description</p>
        <span class="badge bg-warning text-dark">@Model.PriorityName</span>
        <span class="badge bg-info text-dark">@Model.StatusName</span>
        <div class="mt-2">
            <small class="text-muted">
                Dự án: @Model.ProjectName &nbsp;|&nbsp; Hạn: @Model.DueDate?.ToString("dd/MM/yyyy")
                &nbsp;|&nbsp; Tạo bởi @Model.CreatedByName
            </small>
        </div>
    </div>
    @if ((bool)(ViewBag.CanManage ?? false))
    {
        <a asp-action="Edit" asp-route-id="@Model.TaskId" class="btn btn-outline-primary btn-sm">Sửa</a>
    }
</div>

@if ((bool)(ViewBag.CanManage ?? false))
{
    <form asp-action="UpdateStatus" method="post" class="d-flex gap-2 mb-4" style="max-width:320px;">
        <input type="hidden" name="id" value="@Model.TaskId" />
        <input type="hidden" name="projectId" value="@Model.ProjectId" />
        <select name="status" asp-items="ViewBag.StatusOptions" class="form-select">
            <option disabled selected>Đổi trạng thái...</option>
        </select>
        <button type="submit" class="btn btn-primary">Cập nhật</button>
    </form>
}

<h5>Người được giao</h5>
<ul class="list-group mb-3" style="max-width:500px;">
    @foreach (var a in Model.AssignedUsers)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
                <div>@a.FullName</div>
                <small class="text-muted">@a.UserName</small>
            </div>
            @if ((bool)(ViewBag.CanManage ?? false))
            {
                <form asp-action="UnassignUser" method="post">
                    <input type="hidden" name="taskId" value="@Model.TaskId" />
                    <input type="hidden" name="userId" value="@a.UserId" />
                    <button type="submit" class="btn btn-sm btn-outline-danger">Hủy giao</button>
                </form>
            }
        </li>
    }
</ul>
@if (!Model.AssignedUsers.Any())
{
    <p class="text-muted">Chưa giao cho ai.</p>
}

@if ((bool)(ViewBag.CanManage ?? false) && ViewBag.AssignableUsers != null)
{
    <form asp-action="AssignUser" method="post" class="d-flex gap-2" style="max-width:400px;">
        <input type="hidden" name="taskId" value="@Model.TaskId" />
        <select name="userId" class="form-select" asp-items="ViewBag.AssignableUsers"></select>
        <button type="submit" class="btn btn-primary">Giao việc</button>
    </form>
}

<hr class="my-4" />

<!-- Attachments -->
<h5>Tệp đính kèm</h5>
<ul class="list-group mb-2" style="max-width:600px;">
    @foreach (var f in (IEnumerable<TaskManagementSystem.Service.DTOs.Attachment.AttachmentDto>)ViewBag.Attachments)
    {
        <li class="list-group-item d-flex justify-content-between align-items-center">
            <div>
                <a asp-controller="Attachments" asp-action="Download" asp-route-id="@f.AttachmentId">@f.FileName</a>
                <div><small class="text-muted">@f.UploadedByName • @f.UploadedDate.ToString("dd/MM/yyyy HH:mm")</small></div>
            </div>
            <form asp-controller="Attachments" asp-action="Delete" method="post"
                  onsubmit="return confirm('Xóa file này?');">
                <input type="hidden" name="attachmentId" value="@f.AttachmentId" />
                <input type="hidden" name="taskId" value="@Model.TaskId" />
                <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
            </form>
        </li>
    }
</ul>
<form asp-controller="Attachments" asp-action="Upload" method="post" enctype="multipart/form-data" class="d-flex gap-2 mb-4" style="max-width:600px;">
    <input type="hidden" name="taskId" value="@Model.TaskId" />
    <input type="file" name="file" class="form-control" required />
    <button type="submit" class="btn btn-primary">Tải lên</button>
</form>

<!-- Comments -->
<h5>Bình luận</h5>
<div class="mb-3" style="max-width:700px;">
    @foreach (var c in (IEnumerable<TaskManagementSystem.Service.DTOs.Comment.CommentDto>)ViewBag.Comments)
    {
        <div class="border rounded p-2 mb-2">
            <div class="d-flex justify-content-between">
                <strong>@c.UserName</strong>
                <small class="text-muted">@c.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
            </div>
            <p class="mb-1">@c.Content</p>
            @if (c.UserId == ViewBag.CurrentUserId || User.IsInRole("Admin"))
            {
                <form asp-controller="Comments" asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" name="commentId" value="@c.CommentId" />
                    <input type="hidden" name="taskId" value="@Model.TaskId" />
                    <button type="submit" class="btn btn-link btn-sm p-0 text-danger">Xóa</button>
                </form>
            }
        </div>
    }
</div>
<form asp-controller="Comments" asp-action="Add" method="post" class="mb-4" style="max-width:700px;">
    <input type="hidden" name="taskId" value="@Model.TaskId" />
    <div class="input-group">
        <textarea name="content" class="form-control" rows="2" placeholder="Viết bình luận..." required></textarea>
        <button type="submit" class="btn btn-primary">Gửi</button>
    </div>
</form>

<!-- History -->
<h5>Lịch sử thay đổi trạng thái</h5>
<ul class="list-group mb-4" style="max-width:700px;">
    @foreach (var h in (IEnumerable<TaskManagementSystem.Service.DTOs.TaskHistory.TaskHistoryDto>)ViewBag.History)
    {
        <li class="list-group-item">
            <strong>@h.OldStatusName</strong> → <strong>@h.NewStatusName</strong>
            <div><small class="text-muted">bởi @h.ChangedByName • @h.ChangedDate.ToString("dd/MM/yyyy HH:mm")</small></div>
        </li>
    }
</ul>
@if (!((IEnumerable<TaskManagementSystem.Service.DTOs.TaskHistory.TaskHistoryDto>)ViewBag.History).Any())
{
    <p class="text-muted">Chưa có lịch sử thay đổi.</p>
}

<div class="mt-4">
    <a asp-controller="Projects" asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-secondary">Quay lại dự án</a>
</div>